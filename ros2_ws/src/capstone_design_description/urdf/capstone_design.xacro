</joint>

<joint name="lidar" type="fixed">
  <origin xyz="0.0 -0.296 0.3977" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lidar_1"/>
</joint>

<joint name="camera" type="fixed">
  <origin xyz="0.008 -0.01 0.03116" rpy="0 0 0"/>
  <parent link="hand_link_1"/>
  <child link="stereo_camera_1"/>
</joint>

</robot>
