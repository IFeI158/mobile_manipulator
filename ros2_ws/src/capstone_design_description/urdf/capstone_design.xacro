  <child link="left_gripper_link_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
  <limit upper="0.0" lower="-1.22173" effort="100" velocity="100"/>
</joint>

<joint name="hand_link_to_right_gripper_link" type="revolute">
  <origin xyz="0.038 0.005 0.0475" rpy="0 0 0"/>
  <parent link="hand_link_1"/>
  <child link="right_gripper_link_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
  <mimic joint="hand_link_to_left_gripper_link" multiplier="-1.0" offset="0.0"/>
  <limit upper="1.22173" lower="0.0" effort="100" velocity="100"/>
</joint>

<joint name="left_gripper_link_to_left_finger" type="revolute">
  <origin xyz="0.0 -0.005 0.03" rpy="0 0 0"/>
  <parent link="left_gripper_link_1"/>
